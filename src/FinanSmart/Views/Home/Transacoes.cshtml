@model TransactionsViewModel
@{
    ViewData["Title"] = "Transações";
    var ptBR = System.Globalization.CultureInfo.GetCultureInfo("pt-BR");
    var categories = new[] { "Alimentação","Transporte","Moradia","Saúde","Educação","Lazer","Salário","Investimento","Freelance","Outros" };
}

<div class="page-header">
    <h1>Transações</h1>
    <p class="subtitle">Gerencie suas receitas e despesas</p>
</div>

<div class="form-card">
    <h3>Nova Transação</h3>

    @if (TempData["Error"] != null)
    {
        <p class="error-msg">⚠️ @TempData["Error"]</p>
    }

    <form method="post" action="/Home/Adicionar">
        <div class="form-grid">
            <div class="form-group">
                <label>Descrição</label>
                <input type="text" name="Description" placeholder="Ex: Salário, Aluguel..." required />
            </div>
            <div class="form-group">
                <label>Valor (R$)</label>
                <input type="number" name="Amount" min="0.01" step="0.01" required />
            </div>
            <div class="form-group">
                <label>Tipo</label>
                <select name="Type">
                    <option value="0">📈 Receita</option>
                    <option value="1">📉 Despesa</option>
                </select>
            </div>
            <div class="form-group">
                <label>Categoria</label>
                <select name="Category">
                    @foreach (var cat in categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Data</label>
                <input type="date" name="Date" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <button type="submit" class="btn btn-primary">➕ Adicionar</button>
    </form>
</div>

<div class="section-title">Histórico</div>

@if (!Model.Transactions.Any())
{
    <div class="empty-state">
        <p>Nenhuma transação registrada.</p>
    </div>
}
else
{
    <div class="transaction-list">
        @foreach (var t in Model.Transactions)
        {
            <div class="transaction-item">
                <div class="transaction-icon">@(t.Type == TransactionType.Income ? "📈" : "📉")</div>
                <div class="transaction-details">
                    <span class="transaction-desc">@t.Description</span>
                    <span class="transaction-cat">@t.Category · @t.Date.ToString("dd/MM/yyyy")</span>
                </div>
                <span class="transaction-amount @(t.Type == TransactionType.Income ? "positive" : "negative")">
                    @(t.Type == TransactionType.Income ? "+" : "-")@t.Amount.ToString("C", ptBR)
                </span>
                <form method="post" action="/Home/Excluir" style="display:inline">
                    <input type="hidden" name="id" value="@t.Id" />
                    <button type="submit" class="btn-delete" title="Excluir">🗑️</button>
                </form>
            </div>
        }
    </div>
}
